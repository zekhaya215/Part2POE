<Window x:Class="CyberSecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Bot"
        Height="700"
        Width="950"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow">

    <!-- BEAUTIFUL BACKGROUND -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F2027" Offset="0"/>
            <GradientStop Color="#203A43" Offset="0.5"/>
            <GradientStop Color="#2C5364" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="15">

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                CornerRadius="20"
                Padding="20"
                Margin="0,0,0,15">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00C6FF" Offset="0"/>
                    <GradientStop Color="#0072FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Orientation="Horizontal">

                <TextBlock Text="🛡"
                           FontSize="35"
                           Margin="0,0,15,0"/>

                <StackPanel>
                    <TextBlock Text="CyberSecurity Awareness Bot"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Stay Safe. Stay Smart. Stay Secure."
                               FontSize="14"
                               Foreground="White"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <Border Grid.Row="1"
                CornerRadius="20"
                Padding="15"
                Margin="0,0,0,15"
                BorderBrush="#00C6FF"
                BorderThickness="2">

            <Border.Background>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.10"/>
            </Border.Background>

            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatPanel">
                    <!-- Messages appear here -->
                </StackPanel>

            </ScrollViewer>
        </Border>

        <!-- INPUT AREA -->
        <Border Grid.Row="2"
                CornerRadius="20"
                Padding="15">

            <Border.Background>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.10"/>
            </Border.Background>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- INPUT TEXTBOX -->
                <TextBox x:Name="UserInputTextBox"
                         Grid.Column="0"
                         Height="45"
                         FontSize="15"
                         Padding="12"
                         Background="White"
                         Foreground="Black"
                         BorderBrush="#00C6FF"
                         BorderThickness="2"
                         VerticalContentAlignment="Center"
                         Margin="0,0,10,0"
                         KeyDown="UserInputTextBox_KeyDown"/>

                <!-- SEND BUTTON -->
                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send 🚀"
                        Width="120"
                        Height="45"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SendButton_Click"
                        Margin="0,0,10,0"
                        Cursor="Hand">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#11998E" Offset="0"/>
                            <GradientStop Color="#38EF7D" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>
                

                <!-- CLEAR BUTTON -->
                <Button x:Name="ClearButton"
                        Grid.Column="2"
                        Content="Clear 🗑"
                        Width="120"
                        Height="45"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="White"
                        BorderThickness="0"
                        
                        Cursor="Hand">

                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF416C" Offset="0"/>
                            <GradientStop Color="#FF4B2B" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>

                </Button>

            </Grid>

        </Border>

    </Grid>
</Window>